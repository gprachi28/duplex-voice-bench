# LiveKit Cloud — get from https://cloud.livekit.io project settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Smart Turn v3 ONNX weights (gitignored, download separately)
SMART_TURN_MODEL_PATH=models/smart-turn-v3/onnx/model.onnx

# Ollama LLM (optional — defaults to http://localhost:11434 if unset)
OLLAMA_HOST=http://localhost:11434

# Skip huggingface.co's cache-freshness check for mlx-whisper/Kokoro --
# it can hang past the worker's job-init timeout even with weights cached
HF_HUB_OFFLINE=1

# Shared between the worker and the FastAPI sidecar (separate processes) --
# the worker appends one JSON line per turn here, the sidecar reads it to
# serve GET /metrics. Defaults to /tmp/voice-agent-metrics.jsonl if unset.
METRICS_LOG_PATH=/tmp/voice-agent-metrics.jsonl
