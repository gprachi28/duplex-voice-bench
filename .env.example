# LiveKit Cloud — get from https://cloud.livekit.io project settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Smart Turn v3 ONNX weights (gitignored, download separately)
SMART_TURN_MODEL_PATH=models/smart-turn-v3/onnx/model.onnx

# Ollama LLM (optional — defaults to http://localhost:11434 if unset)
OLLAMA_HOST=http://localhost:11434
